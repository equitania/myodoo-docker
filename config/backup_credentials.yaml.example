# Backup Credentials Configuration Example
# IMPORTANT: 
# 1. Copy this file to backup_credentials.yaml
# 2. Set secure permissions (chmod 600)
# 3. NEVER commit the actual credentials file to version control

credentials:
  # Global encryption key for all backups
  # You can either:
  # 1. Set it directly here (less secure)
  global_key: "your-secure-password-here"
  
  # 2. Or use an environment variable (recommended)
  # Set the BACKUP_ENCRYPT_KEY environment variable:
  # export BACKUP_ENCRYPT_KEY='your-secure-password-here'
