# Backup and Update Aliases
# Version 1.0.0 | 28.01.2026

# Backup operations
alias dobk='$HOME/container2backup.py'
alias edbk='mcedit $HOME/container2backup.yaml'
alias llbk='ll /opt/backups/docker'
