# =============================================================
# Environment variables for myodoo-docker scripts
# =============================================================
# Install to the central config directory:
#   mkdir -p /root/.config/myodoo-docker
#   cp .env.example /root/.config/myodoo-docker/.env
#   chmod 600 /root/.config/myodoo-docker/.env
#
# Used by: container2backup.py, server_hardening.py, nginx-cert-guard.py
# NOT used by: update_docker_odoo.py — its DB password comes from docker2update.yaml
#   (set db_password_via_env: true per container to pass it via PGPASSWORD env var
#   instead of --db_password=... in argv, which would be visible in ps aux)
# =============================================================

# Backup encryption settings (container2backup.py)
# When BACKUP_ENCRYPTION_ENABLED=true and format=7z:
#   PRIMARY:  GPG symmetric AES-256 encryption (gpg --symmetric --cipher-algo AES256).
#             Output file: <name>.7z.gpg  |  Restore: gpg -d backup.7z.gpg > backup.7z
#             Passphrase is passed via file descriptor — never visible in ps aux.
#             Requires: gnupg installed (sudo apt-get install gnupg)
#   FALLBACK: If gnupg is NOT installed, falls back to 7z-internal AES (-p flag).
#             Output file: <name>.7z  |  WARNING: password visible in ps aux!
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_PASSWORD=your-secure-password-here

# Server hardening settings
SSH_PORT=22

# Allowed IPs for firewall (UFW) and fail2ban (ignoreip)
# DYNAMIC: define as many ALLOWED_IP_<n> as you need — ALLOWED_IP_1, ALLOWED_IP_2,
# ALLOWED_IP_3, ... There is no fixed limit. Each may have an optional
# ALLOWED_IP_<n>_COMMENT. Empty or omitted entries are simply ignored; numbering
# gaps are tolerated. To add a sixth IP just add ALLOWED_IP_6=..., etc.
ALLOWED_IP_1=
ALLOWED_IP_1_COMMENT=Office 1
ALLOWED_IP_2=
ALLOWED_IP_2_COMMENT=Office 2
ALLOWED_IP_3=
ALLOWED_IP_3_COMMENT=Office 3

# nginx-cert-guard.py — alert email (SMTP relay) sent when a vhost is quarantined
# because its (sub)domain stopped pointing at this server, or on a mass failure.
# Leave ALERT_EMAIL_TO / ALERT_SMTP_HOST empty to disable mail (the guard still
# protects nginx; it just won't notify).
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_SMTP_TLS=starttls          # starttls | ssl | none

# nginx-cert-guard.py — domain guard behaviour
# GUARD_SERVER_IPS: this host's public IPs (comma-separated, v4/v6). RECOMMENDED to
#   set explicitly — Hetzner Floating IPs are not bound to the interface and would
#   be missed by autodetection. Empty = best-effort autodetect.
GUARD_SERVER_IPS=
# Domains that must NEVER be auto-disabled (e.g. Cloudflare-fronted sites whose DNS
# points at Cloudflare, not at us). Comma-separated.
GUARD_IGNORE_DOMAINS=
# Consecutive failing --check runs before a drifted domain's vhost is quarantined.
GUARD_FAIL_THRESHOLD=3
# Mass-failure guard: if more than this many vhosts would be disabled in one run
# (a global fault, not individual customers), disable NOTHING and escalate by mail.
GUARD_MAX_DISABLE=5
