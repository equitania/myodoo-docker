{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "padding": {
      "top": 2
    },
    "type": "small"
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "separator",
    "localip",
    {
      // Public IP lookup bypasses http_proxy (fastfetch uses raw sockets);
      // bound the wait so login never hangs on restricted networks.
      "type": "publicip",
      "timeout": 1000
    },
    "DNS",
    "NetIO",
    "separator",
    "shell",
    "locale",
    "separator",
    "cpu",
    "CPUCache",
    "CPUUsage",
    "Loadavg",
    "separator",
    "memory",
    "swap",
    "separator",
    "disk",
    "DiskIO",
    "Break"
  ]
}
